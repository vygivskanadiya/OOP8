<Window x:Class="StudentJournal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал успішності" Height="700" Width="1020"
        Background="{StaticResource PinkLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PinkMain}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="Журнал успішності студентів" FontSize="18"
                           Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="White" BorderThickness="0">

            <TabItem Header="Студенти">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                            BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Прізвище" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtSLastName" Style="{StaticResource PinkTextBox}" Width="130"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Ім'я" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtSFirstName" Style="{StaticResource PinkTextBox}" Width="110"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Група" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <ComboBox x:Name="CmbSGroup" Width="110" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                <Button Content="Додати"   Style="{StaticResource PinkButton}" Click="AddStudent_Click"    Margin="0,0,6,0"/>
                                <Button Content="Видалити" Style="{StaticResource PinkButton}" Click="DeleteStudent_Click"
                                        Background="{StaticResource PinkDark}" Margin="0,0,6,0"/>
                                <Button Content="Зберегти" Style="{StaticResource PinkButton}" Click="UpdateStudent_Click"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="GridStudents" Style="{StaticResource PinkDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="GridStudents_Changed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Прізвище Ім'я"  Binding="{Binding FullName}"     Width="*"/>
                            <DataGridTextColumn Header="Група"           Binding="{Binding Group.Name}"   Width="100"/>
                            <DataGridTextColumn Header="Середній бал"    Binding="{Binding AverageGrade}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Успішний"    Binding="{Binding IsPassing, Mode=OneWay}"    Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Margin="0,10,0,6">
                        <TextBlock Text="Успішність вибраного студента (по дисципліні та підсумковим балах):"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PinkDark}"/>
                    </Border>
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="210"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" x:Name="GridStudentGrades" Style="{StaticResource PinkDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Предмет"       Binding="{Binding SubjectName}" Width="*"/>
                                <DataGridTextColumn Header="Оцінка"        Binding="{Binding Value}"       Width="80"/>
                                <DataGridCheckBoxColumn Header="Зараховано" Binding="{Binding IsPassing, Mode=OneWay}"  Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Background="{StaticResource PinkLight}" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="TxtStudentName"   FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PinkDark}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtStudentGroup"  FontSize="11" Margin="0,3,0,0" Foreground="Gray"/>
                                <Separator Margin="0,6,0,6" Background="{StaticResource PinkAccent}"/>
                                <TextBlock x:Name="TxtStudentAvg"    FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtStudentStatus" FontSize="13" Margin="0,4,0,0"/>
                                <TextBlock x:Name="TxtStudentCount"  FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Групи">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,14,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                                BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Назва групи" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtGroupName" Style="{StaticResource PinkTextBox}" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Button Content="Додати"        Style="{StaticResource PinkButton}" Click="AddGroup_Click"    Margin="0,0,6,4"/>
                                    <Button Content="Видалити"      Style="{StaticResource PinkButton}" Click="DeleteGroup_Click"
                                            Background="{StaticResource PinkDark}" Margin="0,0,6,4"/>
                                    <Button Content="Зберегти назву" Style="{StaticResource PinkButton}" Click="UpdateGroup_Click" Margin="0,0,0,4"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="GridGroups" Style="{StaticResource PinkDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionChanged="GridGroups_Changed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Назва"     Binding="{Binding Name}"         Width="*"/>
                                <DataGridTextColumn Header="Студентів" Binding="{Binding StudentCount}" Width="80"/>
                                <DataGridTextColumn Header="Сер. бал"  Binding="{Binding GroupAverage}" Width="75"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="TxtGroupTitle"
                                   Text="Для роботи оберіть групу зі списку"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PinkDark}" Margin="0,0,0,8"/>

                        <Border Grid.Row="1" x:Name="PanelGroupInfo" Visibility="Collapsed"
                                Background="{StaticResource PinkLight}" CornerRadius="8"
                                Padding="14" Margin="0,0,0,10">
                            <WrapPanel>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Студентів"         FontSize="11" Foreground="Gray"/>
                                    <TextBlock x:Name="TxtGrpCount"     FontSize="26" FontWeight="Bold" Foreground="{StaticResource PinkDark}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Середній бал"      FontSize="11" Foreground="Gray"/>
                                    <TextBlock x:Name="TxtGrpAvg"       FontSize="26" FontWeight="Bold" Foreground="{StaticResource PinkDark}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Успішних"          FontSize="11" Foreground="Gray"/>
                                    <TextBlock x:Name="TxtGrpPassing"   FontSize="26" FontWeight="Bold" Foreground="{StaticResource PinkDark}"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>

                        <DataGrid Grid.Row="2" x:Name="GridGroupStudents" Style="{StaticResource PinkDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Прізвище Ім'я" Binding="{Binding FullName}"     Width="*"/>
                                <DataGridTextColumn Header="Середній бал"  Binding="{Binding AverageGrade}" Width="110"/>
                                <DataGridCheckBoxColumn Header="Успішний"  Binding="{Binding IsPassing, Mode=OneWay}"    Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Викладачі">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                            BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Прізвище" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtTLastName"  Style="{StaticResource PinkTextBox}" Width="130"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Ім'я" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtTFirstName" Style="{StaticResource PinkTextBox}" Width="110"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Предмет" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <ComboBox x:Name="CmbTSubject" Width="150" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                <Button Content="Додати"   Style="{StaticResource PinkButton}" Click="AddTeacher_Click"    Margin="0,0,6,0"/>
                                <Button Content="Видалити" Style="{StaticResource PinkButton}" Click="DeleteTeacher_Click"
                                        Background="{StaticResource PinkDark}"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="GridTeachers" Style="{StaticResource PinkDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Прізвище Ім'я" Binding="{Binding FullName}"      Width="*"/>
                            <DataGridTextColumn Header="Предмет"       Binding="{Binding Subject.Name}"  Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Предмети">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                            BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Назва предмету" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtSubjectName" Style="{StaticResource PinkTextBox}" Width="200"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                <Button Content="Додати"   Style="{StaticResource PinkButton}" Click="AddSubject_Click"    Margin="0,0,6,0"/>
                                <Button Content="Видалити" Style="{StaticResource PinkButton}" Click="DeleteSubject_Click"
                                        Background="{StaticResource PinkDark}"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="GridSubjects" Style="{StaticResource PinkDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Назва предмету" Binding="{Binding Name}"             Width="*"/>
                            <DataGridTextColumn Header="Викладач"       Binding="{Binding Teacher.FullName}"  Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Оцінки">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                            BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Студент" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <ComboBox x:Name="CmbGStudent" Width="160" FontSize="13"
                                          SelectionChanged="CmbGStudent_Changed"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Предмет" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <ComboBox x:Name="CmbGSubject" Width="160" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Оцінка (0–100)" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                <TextBox x:Name="TxtGradeVal" Style="{StaticResource PinkTextBox}" Width="90"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                <Button Content="Додати / Змінити" Style="{StaticResource PinkButton}" Click="AddGrade_Click"    Margin="0,0,6,0"/>
                                <Button Content="Видалити"         Style="{StaticResource PinkButton}" Click="DeleteGrade_Click"
                                        Background="{StaticResource PinkDark}"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="GridGrades" Style="{StaticResource PinkDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Предмет"       Binding="{Binding SubjectName}" Width="*"/>
                            <DataGridTextColumn Header="Оцінка"        Binding="{Binding Value}"       Width="100"/>
                            <DataGridCheckBoxColumn Header="Зараховано" Binding="{Binding IsPassing, Mode=OneWay}"  Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Пошук">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10"
                            BorderBrush="{StaticResource PinkAccent}" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Ім'я/Прізвище" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <TextBox x:Name="TxtSearchName" Style="{StaticResource PinkTextBox}" Width="150"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Група" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <ComboBox x:Name="CmbSearchGroup" Width="120" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Мін. бал" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <TextBox x:Name="TxtSearchMin" Style="{StaticResource PinkTextBox}" Width="80"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Макс. бал" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <TextBox x:Name="TxtSearchMax" Style="{StaticResource PinkTextBox}" Width="80"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Статус" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <ComboBox x:Name="CmbSearchStatus" Width="150" FontSize="13">
                                        <ComboBoxItem Content="Всі" IsSelected="True"/>
                                        <ComboBoxItem Content="Тільки успішні"/>
                                        <ComboBoxItem Content="Тільки неуспішні"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Успішність" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <ComboBox x:Name="CmbSearchSubject" Width="160" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Text="" FontSize="11" Foreground="{StaticResource PinkMain}"/>
                                    <ComboBox x:Name="CmbSearchSubjectStatus" Width="150" FontSize="13">
                                        <ComboBoxItem Content="Будь-який" IsSelected="True"/>
                                        <ComboBoxItem Content="Склав предмет"/>
                                        <ComboBoxItem Content="Не склав предмет"/>
                                    </ComboBox>
                                </StackPanel>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Знайти" Style="{StaticResource PinkButton}" Click="Search_Click"      Margin="0,0,8,0"/>
                                <Button Content="Скинути"    Style="{StaticResource PinkButton}" Click="SearchReset_Click"
                                        Background="{StaticResource PinkDark}"/>
                                <TextBlock x:Name="TxtSearchCount" VerticalAlignment="Center"
                                           Margin="16,0,0,0" FontSize="12" Foreground="{StaticResource PinkDark}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="230"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" x:Name="GridSearch" Style="{StaticResource PinkDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0"
                                  SelectionChanged="GridSearch_Changed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Прізвище Ім'я"  Binding="{Binding FullName}"     Width="*"/>
                                <DataGridTextColumn Header="Група"           Binding="{Binding Group.Name}"   Width="100"/>
                                <DataGridTextColumn Header="Середній бал"    Binding="{Binding AverageGrade}" Width="110"/>
                                <DataGridCheckBoxColumn Header="Успішний"    Binding="{Binding IsPassing, Mode=OneWay}"    Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" x:Name="PanelSearchDetail" Visibility="Collapsed"
                                Background="{StaticResource PinkLight}" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="TxtSearchDetailName" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PinkDark}" TextWrapping="Wrap"/>
                                <Separator Margin="0,6,0,6" Background="{StaticResource PinkAccent}"/>
                                <TextBlock x:Name="TxtSearchDetailAvg"    FontSize="12"/>
                                <TextBlock x:Name="TxtSearchDetailStatus" FontSize="12" Margin="0,3,0,0"/>
                                <TextBlock Text="Оцінки:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource PinkDark}" Margin="0,8,0,4"/>
                                <ItemsControl x:Name="ListSearchGrades">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12" Margin="0,2">
                                                <Run Text="{Binding SubjectName}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Value}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
